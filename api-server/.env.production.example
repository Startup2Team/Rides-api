# =============================================================================
# Rides API — PRODUCTION env. Copy to `.env` here and fill CHANGEME.
# Lives at /opt/rides/Rides-api/api-server/.env  — NEVER commit the real file.
#
# Generate secrets with:  openssl rand -hex 64
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
ENV=production
PORT=8080
# Admin dashboard origin — REQUIRED for CORS, else the admin is blocked.
ADMIN_ORIGIN=https://admin.rides.rw
# Browser-facing API URL baked into the admin build (compose reads this).
ADMIN_API_URL=https://api.rides.rw/api/v1

# ── Postgres (compose builds DATABASE_URL from these) ────────────────────────
POSTGRES_USER=rides_prod
POSTGRES_PASSWORD=CHANGEME_strong_db_password
POSTGRES_DB=rideplatform

# ── Redis (compose builds REDIS_URL from this) ───────────────────────────────
REDIS_PASSWORD=CHANGEME_strong_redis_password

# ── JWT — generate fresh, do NOT reuse dev secrets ───────────────────────────
JWT_ACCESS_SECRET=CHANGEME_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGEME_openssl_rand_hex_64
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── Africa's Talking — OTP SMS (empty = OTP won't send, logins break) ────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_MASKING_NUMBER=+250000000000

# ── Firebase Cloud Messaging — push (mount the JSON next to compose) ─────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── MTN MoMo Collections ─────────────────────────────────────────────────────
# Live charges need all three of API_USER + API_KEY + SUBSCRIPTION_KEY. Until
# they are set the gateway stays inert (returns mock PENDING) and only manual
# admin confirmation grants credits.
MOMO_API_USER=                 # provisioned API user UUID
MOMO_API_KEY=                  # API key (secret) generated for that API user
MOMO_SUBSCRIPTION_KEY=         # Collections product subscription key
MOMO_ENVIRONMENT=sandbox       # X-Target-Environment: sandbox | mtnrwanda (prod)
# Optional overrides (sane defaults derived from MOMO_ENVIRONMENT):
#   MOMO_BASE_URL=https://proxy.momoapi.mtn.com   # prod host (sandbox auto-used otherwise)
#   MOMO_CURRENCY=RWF                              # sandbox forces EUR automatically
#   MOMO_CALLBACK_URL=https://api.rides.rw/api/v1/webhooks/momo/callback
# REQUIRED in prod: gates the public MoMo callback. Generate a random value.
MOMO_WEBHOOK_SECRET=CHANGEME_openssl_rand_hex_32
# Keep real-money wallet movement OFF until MoMo is integrated AND verified.
# NOTE: package purchases settle via the reconciler regardless; PAYMENTS_ENABLED
# governs driver-wallet payouts, not package buying.
PAYMENTS_ENABLED=false

# Manual-payment flow (riders pay off-platform, then submit proof an admin
# verifies). Surfaced via GET /driver/packages/payment-info. Set these to launch
# manual payments before MoMo is provisioned.
MANUAL_PAY_MOMO_CODE=
MANUAL_PAY_MOMO_NAME=
MANUAL_PAY_INSTRUCTIONS=

# ── API protection ───────────────────────────────────────────────────────────
# Per-IP global request cap per minute (DDoS/abuse backstop). Raise if many
# users share one carrier-NAT IP and hit false 429s; lower to tighten.
GLOBAL_RATE_LIMIT_PER_MIN=300
# Max non-upload request body in bytes (memory-exhaustion guard). Default 1 MiB.
MAX_REQUEST_BODY_BYTES=1048576
# API docs (/swagger). Off by default in production. To expose it safely set
# SWAGGER_ENABLED=true AND SWAGGER_BASIC_AUTH=user:pass (HTTP Basic prompt).
SWAGGER_ENABLED=false
SWAGGER_BASIC_AUTH=

# ── Object storage — Cloudflare R2 (driver documents) ────────────────────────
STORAGE_PROVIDER=r2
STORAGE_BUCKET=rides-docs
STORAGE_REGION=auto
STORAGE_KEY_ID=
STORAGE_SECRET=
STORAGE_CDN_URL=https://cdn.rides.rw
# Leave STORAGE_ENDPOINT empty for R2 (only set for MinIO/self-hosted S3).

# ── Database backups (scripts/pg-backup.sh, run daily via cron) ───────────────
# Reuses the STORAGE_* R2 creds above; dumps go to s3://$STORAGE_BUCKET/db-backups/.
# AES-256 encrypts each dump. ⚠️ KEEP A COPY OF THIS KEY OFF THE BOX (password
# manager) — losing it makes every backup unrecoverable. Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
BACKUP_RETAIN_DAYS=14

# ── Production safety gates (must stay false) ────────────────────────────────
DEV_SKIP_GEOFENCE=false
DEV_AUTO_APPROVE_DRIVERS=false

# Matching / ride / penalty tuning use built-in defaults; override here only if
# you need to (see config/config.go for the full list).
