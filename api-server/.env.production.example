# =============================================================================
# Rides API — PRODUCTION env. Copy to `.env` here and fill CHANGEME.
# Lives at /opt/rides/Rides-api/api-server/.env  — NEVER commit the real file.
#
# Generate secrets with:  openssl rand -hex 64
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
ENV=production
PORT=8080
# Admin dashboard origin — REQUIRED for CORS, else the admin is blocked.
ADMIN_ORIGIN=https://admin.rides.rw
# Browser-facing API URL baked into the admin build (compose reads this).
ADMIN_API_URL=https://api.rides.rw/api/v1

# ── Postgres (compose builds DATABASE_URL from these) ────────────────────────
POSTGRES_USER=rides_prod
POSTGRES_PASSWORD=CHANGEME_strong_db_password
POSTGRES_DB=rideplatform

# ── Redis (compose builds REDIS_URL from this) ───────────────────────────────
REDIS_PASSWORD=CHANGEME_strong_redis_password

# ── JWT — generate fresh, do NOT reuse dev secrets ───────────────────────────
JWT_ACCESS_SECRET=CHANGEME_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGEME_openssl_rand_hex_64
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── Africa's Talking — OTP SMS (empty = OTP won't send, logins break) ────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_MASKING_NUMBER=+250000000000

# ── Firebase Cloud Messaging — push (mount the JSON next to compose) ─────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── MTN MoMo ─────────────────────────────────────────────────────────────────
MOMO_API_KEY=
MOMO_SUBSCRIPTION_KEY=
MOMO_ENVIRONMENT=sandbox
# REQUIRED in prod: gates the public MoMo callback. Generate a random value.
MOMO_WEBHOOK_SECRET=CHANGEME_openssl_rand_hex_32
# Keep real-money wallet movement OFF until MoMo is integrated AND verified.
PAYMENTS_ENABLED=false

# ── Object storage — Cloudflare R2 (driver documents) ────────────────────────
STORAGE_PROVIDER=r2
STORAGE_BUCKET=rides-docs
STORAGE_REGION=auto
STORAGE_KEY_ID=
STORAGE_SECRET=
STORAGE_CDN_URL=https://cdn.rides.rw
# Leave STORAGE_ENDPOINT empty for R2 (only set for MinIO/self-hosted S3).

# ── Production safety gates (must stay false) ────────────────────────────────
DEV_SKIP_GEOFENCE=false
DEV_AUTO_APPROVE_DRIVERS=false

# Matching / ride / penalty tuning use built-in defaults; override here only if
# you need to (see config/config.go for the full list).
