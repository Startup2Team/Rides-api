{
  "info": {
    "_postman_id": "a90df2cd-cb41-4770-9831-cb03f47e2469",
    "name": "Ride-Hailing & Delivery Platform API",
    "description": "Comprehensive Postman collection for testing the Go (Chi) Ride-Hailing & Delivery Platform backend. Collection-level auth uses {{accessToken}} bearer token — set it after calling Verify OTP. Public endpoints override auth to 'noauth'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "description": "Server liveness probe.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns {\"status\":\"ok\"} when the server is up."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth (Public)",
      "description": "Endpoints for user registration, OTP verification, refreshing tokens, and logging out.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"+250780000000\",\n  \"device_id\": \"device_iphone15_pro\",\n  \"platform\": \"ios\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Sends a verification OTP SMS to the specified phone number. Captures device ID to detect multi-account collisions. Rate-limited to 5 requests per hour per IP."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"+250780000000\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-otp"]
            },
            "description": "Verifies the received OTP. Returns access_token, refresh_token, and role_state. Copy these values into the {{accessToken}} and {{refreshToken}} collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Uses a valid, non-expired refresh token to generate a brand new short-lived access token."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Blacklists the current user session refresh token in Redis. Requires Authorization: Bearer {{accessToken}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Customer",
      "description": "Endpoints accessed by customers (roles: CUSTOMER_ONLY, DRIVER_ACTIVE, DRIVER_PENDING). All require Authorization: Bearer {{accessToken}}.",
      "item": [
        {
          "name": "Get Customer Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "profile"]
            },
            "description": "Fetches current customer user details."
          },
          "response": []
        },
        {
          "name": "Update Customer Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"fcm_token\": \"fcm_token_placeholder\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "profile"]
            },
            "description": "Updates profile details like full name and Firebase push token."
          },
          "response": []
        },
        {
          "name": "Fetch Nearby Drivers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lat\": -1.9441,\n  \"lng\": 30.0619,\n  \"transport_type\": \"MOTO_BIKE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/location",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "location"]
            },
            "description": "Fetches lists of nearby drivers for a given transport type. Returns anonymized distance and vehicle types only (identity hidden for privacy). transport_type: MOTO_BIKE | CAB_TAXI | HEAVY_FUSO | LIGHT_HILUX."
          },
          "response": []
        },
        {
          "name": "Book Ride",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_lat\": -1.9441,\n  \"pickup_lng\": 30.0619,\n  \"pickup_address\": \"Kigali Heights, Kigali\",\n  \"dest_lat\": -1.9582,\n  \"dest_lng\": 30.0912,\n  \"dest_address\": \"Kigali International Airport\",\n  \"transport_type\": \"MOTO_BIKE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides"]
            },
            "description": "Creates a ride booking request. Triggers matching engine to find the closest available driver."
          },
          "response": []
        },
        {
          "name": "List Ride History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieves a paginated list of all customer's previous rides."
          },
          "response": []
        },
        {
          "name": "Get Ride Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides/{{rideId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides", "{{rideId}}"]
            },
            "description": "Fetches current details of a specific ride. Driver metadata is blank until matching reaches CONFIRMED state."
          },
          "response": []
        },
        {
          "name": "Cancel Ride",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides/{{rideId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides", "{{rideId}}"]
            },
            "description": "Cancels a pending ride request. Tracked in Redis; abusing cancellations triggers suspensions."
          },
          "response": []
        },
        {
          "name": "Negotiation: Propose Fare",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1500.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides/{{rideId}}/negotiation/propose",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides", "{{rideId}}", "negotiation", "propose"]
            },
            "description": "Counter-propose a ride fare. Max 4 total rounds of automatic in-app bidding."
          },
          "response": []
        },
        {
          "name": "Negotiation: Accept Fare",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides/{{rideId}}/negotiation/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides", "{{rideId}}", "negotiation", "accept"]
            },
            "description": "Accepts the driver's current fare offer, locking the ride price."
          },
          "response": []
        },
        {
          "name": "Negotiation: Decline Fare",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customer/rides/{{rideId}}/negotiation/decline",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customer", "rides", "{{rideId}}", "negotiation", "decline"]
            },
            "description": "Rejects the driver's fare. Advances negotiation rounds."
          },
          "response": []
        }
      ]
    },
