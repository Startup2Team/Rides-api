                  "key": "pickup_lng",
                  "value": "30.0619"
                },
                {
                  "key": "dest_lat",
                  "value": "-1.9582"
                },
                {
                  "key": "dest_lng",
                  "value": "30.0912"
                },
                {
                  "key": "vehicle_type",
                  "value": "MOTO_BIKE"
                }
              ]
            },
            "description": "Looks up a cached route (distance_km, duration_minutes, fare_rwf) for the given pickup/destination pair and vehicle type. vehicle_type: MOTO_BIKE | CAB_TAXI | LIGHT_HILUX | HEAVY_FUSO."
          },
          "response": []
        },
