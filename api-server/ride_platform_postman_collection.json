    {
      "name": "WebSocket",
      "description": "WebSocket connections for real-time events. Use Postman's built-in WebSocket client (New → WebSocket). Auth is passed via the Authorization header: Bearer {{accessToken}}.",
      "item": [
        {
          "name": "Driver WebSocket",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "Required — JWT access token"
              },
              {
                "key": "Upgrade",
                "value": "websocket"
              },
              {
                "key": "Connection",
                "value": "Upgrade"
              }
            ],
            "url": {
              "raw": "ws://{{wsBaseUrl}}/ws/driver",
              "protocol": "ws",
              "host": ["{{wsBaseUrl}}"],
              "path": ["ws", "driver"]
            },
            "description": "WebSocket endpoint for active drivers. Send location updates as JSON: {\"type\":\"location_update\",\"lat\":-1.9448,\"lng\":30.0625,\"speed_kmh\":35.5,\"heading\":180.0}. Receives ride dispatch events and negotiation messages. Use Postman's WebSocket client, not the REST runner."
          },
          "response": []
        },
        {
          "name": "Customer WebSocket",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "Required — JWT access token"
              },
              {
                "key": "Upgrade",
                "value": "websocket"
              },
              {
                "key": "Connection",
                "value": "Upgrade"
              }
            ],
            "url": {
              "raw": "ws://{{wsBaseUrl}}/ws/customer?ride_id={{rideId}}",
              "protocol": "ws",
              "host": ["{{wsBaseUrl}}"],
              "path": ["ws", "customer"],
              "query": [
                {
                  "key": "ride_id",
                  "value": "{{rideId}}",
                  "description": "Required — active ride UUID"
                }
              ]
            },
            "description": "WebSocket endpoint for customers tracking an active ride. Receives driver location updates, arrival events, and ride completion. Connect after ride reaches CONFIRMED state. ride_id query param is required. Use Postman's WebSocket client, not the REST runner."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL for REST requests. Change to your deployed URL for staging/prod."
    },
    {
      "key": "wsBaseUrl",
      "value": "localhost:8080",
      "type": "string",
      "description": "Host for WebSocket connections (no http:// prefix). Change for staging/prod."
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT access token returned by POST /auth/verify-otp. Short-lived (~15 min). Refresh with POST /auth/refresh."
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string",
      "description": "Refresh token returned by POST /auth/verify-otp. Used to obtain new access tokens."
    },
    {
      "key": "rideId",
      "value": "",
      "type": "string",
      "description": "UUID of an active ride. Set after calling POST /customer/rides."
    },
    {
      "key": "driverId",
      "value": "",
      "type": "string",
      "description": "UUID of a driver profile (admin use). Get from GET /admin/drivers."
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "UUID of a platform user (admin use). Get from GET /admin/users."
    },
    {
      "key": "savedLocationId",
      "value": "",
      "type": "string",
      "description": "UUID of a saved location. Set after calling POST /users/me/saved-locations."
    }
  ]
}
