            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/locations/route?pickup_lat=-1.9441&pickup_lng=30.0619&dest_lat=-1.9582&dest_lng=30.0912&vehicle_type=MOTO_BIKE",
