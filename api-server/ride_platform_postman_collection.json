        {
          "name": "Accept Ride Request",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "accept"]
            },
            "description": "Accepts a dispatched ride. Enforces strict 15-second response TTL. If expired, request is automatically declined. Requires role DRIVER_ACTIVE."
          },
          "response": []
        },
        {
          "name": "Decline Ride Request",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/decline",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "decline"]
            },
            "description": "Declines a dispatched ride. Increments decline counters in Redis. Exceeding thresholds results in priority demotion or temporary offline suspension."
          },
          "response": []
        },
        {
          "name": "Cancel After Pickup Expiry",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "cancel"]
            },
            "description": "Driver cancels the ride after the pickup window has expired (customer no-show). Requires role DRIVER_ACTIVE."
          },
          "response": []
        },
