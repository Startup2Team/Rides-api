          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/en-route",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "en-route"]
            },
            "description": "Marks the driver as en route to the pickup location. Transitions ride state to EN_ROUTE. Requires role DRIVER_ACTIVE."
          },
          "response": []
        },
        {
          "name": "Arrived at Pickup",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/arrive",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "arrive"]
            },
            "description": "Marks the driver as arrived at the pickup location. Starts the customer pickup countdown. Requires role DRIVER_ACTIVE."
          },
          "response": []
        },
        {
          "name": "Start Ride",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/driver/rides/{{rideId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "driver", "rides", "{{rideId}}", "start"]
