# =============================================================================
# Ride-Hailing Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Server
PORT=8080
ENV=development

# PostgreSQL (must have PostGIS extension enabled)
DATABASE_URL=postgres://ride:ride_secret@localhost:5432/rideplatform?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# =============================================================================
# JWT Secrets — generate strong random strings (64+ chars each)
# Example: openssl rand -hex 64
# =============================================================================
JWT_ACCESS_SECRET=local_dev_access_secret_change_before_any_shared_environment_0123456789
JWT_REFRESH_SECRET=local_dev_refresh_secret_change_before_any_shared_environment_0123456789
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# =============================================================================
# Africa's Talking — OTP SMS + Masked Number
# https://africastalking.com
# =============================================================================
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_MASKING_NUMBER=+250000000000

# =============================================================================
# Firebase Cloud Messaging (FCM) — push notifications
# Download service account JSON from Firebase Console >
# Project Settings > Service Accounts > Generate new private key
# =============================================================================
FIREBASE_SERVICE_ACCOUNT_PATH=

# =============================================================================
# Google Maps Platform
# Enable: Directions API, Distance Matrix API, Geocoding API
# https://console.cloud.google.com
# =============================================================================
GOOGLE_MAPS_API_KEY=

# =============================================================================
# MTN MoMo API — payments
# https://momodeveloper.mtn.com
# =============================================================================
MOMO_API_USER=
MOMO_API_KEY=
MOMO_SUBSCRIPTION_KEY=
MOMO_ENVIRONMENT=sandbox
# Optional: MOMO_BASE_URL, MOMO_CURRENCY, MOMO_CALLBACK_URL (defaults derived from env)

# =============================================================================
# Object storage — document + payment-proof uploads
# LOCAL dev = MinIO (proxy mode); PROD = Cloudflare R2. Set real values only in
# the prod environment's secret store (e.g. Railway variables) — never here.
# =============================================================================
#
# ── Local dev (MinIO, S3-compatible, proxy mode) ────────────────────────────
# STORAGE_PROVIDER=minio          # "minio" turns on proxy mode: the API brokers
#                                 # bytes so the device never needs to reach minio:9000
# STORAGE_BUCKET=rides-docs
# STORAGE_REGION=auto
# STORAGE_KEY_ID=ride_minio
# STORAGE_SECRET=ride_minio_secret
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_CDN_URL=http://localhost:8080/api/v1/uploads/objects  # localhost:8080 is
#                                 # auto-rewritten to the request Host (device IP / ngrok)
#
# ── Prod (Cloudflare R2) ────────────────────────────────────────────────────
# The R2 API host is https://<ACCOUNT_ID>.r2.cloudflarestorage.com and uses the
# Cloudflare ACCOUNT ID (NOT the access-key id). Provide the account id via
# STORAGE_ACCOUNT_ID and the host is built for you; OR set STORAGE_ENDPOINT
# explicitly (it always takes precedence). With provider=r2 the API refuses to
# start unless one of STORAGE_ACCOUNT_ID or STORAGE_ENDPOINT is set.
STORAGE_PROVIDER=r2
STORAGE_BUCKET=rides-docs
STORAGE_REGION=auto
STORAGE_KEY_ID=            # R2 API token Access Key ID (secret — prod env only)
STORAGE_SECRET=           # R2 API token Secret Access Key (secret — prod env only)
STORAGE_ACCOUNT_ID=       # Cloudflare account id — builds the R2 host above
# STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com   # optional explicit override (takes precedence)
STORAGE_CDN_URL=https://<your-public-r2-domain>                  # public bucket/custom domain that serves the objects

# =============================================================================
# Matching Engine Tuning
# =============================================================================
MATCH_RADIUS_PRIMARY_M=5000
MATCH_RADIUS_EXPANDED_M=10000
MATCH_TIMEOUT_SECONDS=15
MATCH_MAX_ATTEMPTS=3

# =============================================================================
# Ride Geo-gate Radii
# =============================================================================
START_RIDE_RADIUS_M=150
COMPLETE_RIDE_RADIUS_M=200
GPS_MAX_SPEED_KMH=200

# =============================================================================
# Driver Penalty Thresholds
# =============================================================================
DRIVER_OFFLINE_COOLDOWN_MINUTES=10
DRIVER_DECLINE_PRIORITY_THRESHOLD=10
DRIVER_DECLINE_AUTO_OFFLINE_THRESHOLD=15

# =============================================================================
# Customer Cancellation Thresholds
# =============================================================================
CUSTOMER_CANCEL_WARN_THRESHOLD=5
CUSTOMER_CANCEL_SUSPEND_THRESHOLD=8
CUSTOMER_CANCEL_SUSPEND_HOURS=2
